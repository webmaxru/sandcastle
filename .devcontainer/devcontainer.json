{
  "name": "Sandcastle",
  "image": "mcr.microsoft.com/devcontainers/base:ubuntu-24.04",
  "features": {
    "ghcr.io/devcontainers/features/python:1": { "version": "3.12" },
    "ghcr.io/devcontainers/features/node:1": { "version": "22" }
  },
  "postCreateCommand": "pip install -r backend/requirements.txt && npm --prefix frontend ci && npm install -g @github/copilot",
  "forwardPorts": [8099, 5173],
  "portsAttributes": {
    "8099": { "label": "backend (uvicorn)" },
    "5173": { "label": "frontend (vite)" }
  },
  "customizations": {
    "vscode": {
      "extensions": [
        "ms-python.python",
        "dbaeumer.vscode-eslint"
      ]
    }
  }
}
