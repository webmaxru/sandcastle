# Cookieless RUM — Azure Application Insights connection string.
#
# This is a PUBLIC, client-side ingestion key (write-only) that is expected to
# ship in the browser bundle. Provide it at BUILD TIME: copy this file to
# `.env` locally, or set it as a repo VARIABLE (not a secret) in CI. Leave it
# empty to disable telemetry entirely (safe no-op — no consent banner needed).
VITE_APPINSIGHTS_CONNECTION_STRING=

# One-line kill switch. Set to "false" to force-disable all telemetry even when
# a connection string is present. Any other value (or unset) keeps RUM on.
VITE_ANALYTICS_ENABLED=true
