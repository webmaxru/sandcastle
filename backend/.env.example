# ---- Model / Copilot CLI ----
# Optional. If unset, the CLI picks a default model.
# GITHUB_COPILOT_MODEL=gpt-5
# GITHUB_COPILOT_TIMEOUT=300

# ---- Auth mode A: Local-first (use your own Copilot) ----
# Fine-grained PAT (personal account) with the "Copilot Requests" permission.
# Classic PATs (ghp_) are NOT supported. Leave unset to use your existing
# `copilot` CLI login on this machine.
# COPILOT_GITHUB_TOKEN=github_pat_xxx

# ---- Auth mode B: Hosted demo (BYOK, ToS-compliant) ----
# Point the CLI at your own OpenAI-compatible provider. BYOK is activated by the
# base URL alone; GitHub auth is NOT required for model requests. A MODEL IS
# REQUIRED (GITHUB_COPILOT_MODEL below) — the CLI exits otherwise.
#
# Free & seat-free — GitHub Models (token needs Models access):
# COPILOT_PROVIDER_BASE_URL=https://models.github.ai/inference
# COPILOT_PROVIDER_API_KEY=github_pat_or_oauth_token
# GITHUB_COPILOT_MODEL=openai/gpt-4o-mini
#
# Stronger / higher-limit — Azure OpenAI (paid):
# COPILOT_PROVIDER_TYPE=azure
# COPILOT_PROVIDER_BASE_URL=https://YOUR-RESOURCE.openai.azure.com
# COPILOT_PROVIDER_API_KEY=your-azure-openai-key
# GITHUB_COPILOT_MODEL=gpt-4o                 # a well-known base model id
# COPILOT_PROVIDER_WIRE_MODEL=your-deployment # if the deployment name differs
#
# Optional advanced knobs:
# COPILOT_PROVIDER_BEARER_TOKEN=...  # sets Authorization header directly (wins over api key)
# COPILOT_PROVIDER_MODEL_ID=gpt-4o   # well-known base for tool/token config

# ---- Session sandbox runtime ----
SANDCASTLE_SESSIONS_ROOT=./.sessions
SANDCASTLE_MAX_SESSIONS=3
SANDCASTLE_SESSION_TIMEOUT=600
# Self-healing budget: how many Fixer passes per build turn.
SANDCASTLE_MAX_FIX_ATTEMPTS=2

# ---- Hardening (hosted demo) ----
# The agent runs real shell/file tools, so throttle the public demo. Off by
# default (local-first repo runs unthrottled); turn on for a hosted deployment.
SANDCASTLE_RATELIMIT=false
SANDCASTLE_RATE_SESSIONS_PER_HOUR=20
SANDCASTLE_RATE_BUILDS_PER_MIN=6
# Safety caps on the streamed activity + file viewer.
# SANDCASTLE_MAX_STREAM_EVENTS=8000
# SANDCASTLE_MAX_EVENT_FIELD_CHARS=8000
# SANDCASTLE_MAX_TEXT_FILE_BYTES=1000000

# ---- MCP grounding (Microsoft Learn) ----
# Ground scaffolding in current Microsoft/Azure docs via the Microsoft Learn MCP.
SANDCASTLE_LEARN_MCP=true
# SANDCASTLE_LEARN_MCP_URL=https://learn.microsoft.com/api/mcp

# ---- Web ----
# Comma-separated allowed origins. Use your Static Web App URL in production.
SANDCASTLE_CORS_ORIGINS=*

# ---- Observability (optional) ----
# Hosted / free-tier path: export OpenTelemetry traces, metrics and logs from
# every agent run + tool call to Azure Application Insights.
# APPLICATIONINSIGHTS_CONNECTION_STRING=InstrumentationKey=...;IngestionEndpoint=https://...
#
# Generic OTLP collector instead of App Insights (auto-detected):
# OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317
#
# Local dev: print spans/metrics to the console (no backend required).
# SANDCASTLE_OTEL_CONSOLE=true
